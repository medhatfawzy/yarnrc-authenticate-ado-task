{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "node16",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "rootDir": "YarnrcAuthenticate",
    "outDir": "YarnrcAuthenticate/dist"
  },
  "include": ["YarnrcAuthenticate/**/*.ts"]
}